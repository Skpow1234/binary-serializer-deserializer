{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 26,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "BSD_BUILD_EXAMPLES": "ON",
                "BSD_WARNINGS_AS_ERRORS": "ON"
            }
        },
        {
            "name": "dev-debug",
            "displayName": "Developer (Debug)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "dev-release",
            "displayName": "Developer (Release)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "ci",
            "displayName": "CI build (warnings-as-errors)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "ci-msvc",
            "displayName": "CI build (MSVC, warnings-as-errors)",
            "inherits": "base",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "cacheVariables": {
                "CMAKE_CONFIGURATION_TYPES": "Debug;Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "dev-debug",
            "configurePreset": "dev-debug"
        },
        {
            "name": "dev-release",
            "configurePreset": "dev-release"
        },
        {
            "name": "ci",
            "configurePreset": "ci"
        },
        {
            "name": "ci-msvc-debug",
            "configurePreset": "ci-msvc",
            "configuration": "Debug"
        },
        {
            "name": "ci-msvc-release",
            "configurePreset": "ci-msvc",
            "configuration": "Release"
        }
    ]
}
