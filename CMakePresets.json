{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 26,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "BSD_BUILD_EXAMPLES": "ON",
                "BSD_WARNINGS_AS_ERRORS": "ON"
            }
        },
        {
            "name": "san-base",
            "hidden": true,
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "dev-debug",
            "displayName": "Developer (Debug)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "dev-release",
            "displayName": "Developer (Release)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "ci",
            "displayName": "CI build (warnings-as-errors)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "ci-msvc",
            "displayName": "CI build (MSVC, warnings-as-errors)",
            "inherits": "base",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "cacheVariables": {
                "CMAKE_CONFIGURATION_TYPES": "Debug;Release"
            }
        },
        {
            "name": "asan",
            "displayName": "AddressSanitizer",
            "inherits": "san-base",
            "cacheVariables": {
                "BSD_ENABLE_ASAN": "ON"
            }
        },
        {
            "name": "ubsan",
            "displayName": "UndefinedBehaviorSanitizer",
            "inherits": "san-base",
            "cacheVariables": {
                "BSD_ENABLE_UBSAN": "ON"
            }
        },
        {
            "name": "asan-ubsan",
            "displayName": "AddressSanitizer + UndefinedBehaviorSanitizer",
            "inherits": "san-base",
            "cacheVariables": {
                "BSD_ENABLE_ASAN": "ON",
                "BSD_ENABLE_UBSAN": "ON"
            }
        },
        {
            "name": "tsan",
            "displayName": "ThreadSanitizer",
            "inherits": "san-base",
            "cacheVariables": {
                "BSD_ENABLE_TSAN": "ON"
            }
        },
        {
            "name": "msan",
            "displayName": "MemorySanitizer (Clang only)",
            "inherits": "san-base",
            "cacheVariables": {
                "BSD_ENABLE_MSAN": "ON",
                "CMAKE_C_COMPILER":  "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        },
        {
            "name": "coverage",
            "displayName": "Code coverage instrumentation",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BSD_ENABLE_COVERAGE": "ON"
            }
        }
    ],
    "buildPresets": [
        { "name": "dev-debug",       "configurePreset": "dev-debug" },
        { "name": "dev-release",     "configurePreset": "dev-release" },
        { "name": "ci",              "configurePreset": "ci" },
        { "name": "ci-msvc-debug",   "configurePreset": "ci-msvc", "configuration": "Debug" },
        { "name": "ci-msvc-release", "configurePreset": "ci-msvc", "configuration": "Release" },
        { "name": "asan",            "configurePreset": "asan" },
        { "name": "ubsan",           "configurePreset": "ubsan" },
        { "name": "asan-ubsan",      "configurePreset": "asan-ubsan" },
        { "name": "tsan",            "configurePreset": "tsan" },
        { "name": "msan",            "configurePreset": "msan" },
        { "name": "coverage",        "configurePreset": "coverage" }
    ]
}
